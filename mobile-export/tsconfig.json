{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@workspace/api-client-react": ["./vendor/api-client-react/src/index.ts"],
      "@workspace/jump-the-book-shared": ["./vendor/jump-the-book-shared/src/index.ts"],
      "@workspace/jump-the-book-shared/*": ["./vendor/jump-the-book-shared/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
